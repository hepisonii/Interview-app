<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register – Interview Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100vh;
      font-family: 'DM Sans', sans-serif;
      background: #f8f8f6;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .card {
      width: 100%;
      max-width: 480px;
      background: #ffffff;
      border: 1px solid #e4e4e0;
      border-radius: 20px;
      padding: 2.5rem 2.25rem;
      box-shadow: 0 2px 24px rgba(0,0,0,0.06);
    }

    /* Brand */
    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1.75rem; }
    .logo {
      width: 36px; height: 36px; border-radius: 10px;
      background: #0f172a; display: flex; align-items: center; justify-content: center;
    }
    .logo i { color: #fff; font-size: 18px; }
    .brand-name { font-size: 13px; font-weight: 600; color: #0f172a; letter-spacing: 0.04em; text-transform: uppercase; }
    .brand-sub { font-size: 11px; color: #9ca3af; margin-top: 1px; }

    /* Heading */
    h1 { font-family: 'Playfair Display', serif; font-size: 26px; color: #0f172a; margin-bottom: 0.25rem; line-height: 1.25; }
    .sub { font-size: 13px; color: #6b7280; margin-bottom: 1.75rem; }

    /* Progress */
    .steps { display: flex; align-items: center; margin-bottom: 2rem; }
    .step-item { display: flex; align-items: center; }
    .dot {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      border: 1px solid #d1d5db;
      background: #f9fafb;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 500; color: #9ca3af;
      transition: all 0.3s;
    }
    .dot.active { background: #0f172a; border-color: #0f172a; color: #fff; }
    .dot.done { background: #059669; border-color: #059669; color: #fff; }
    .line { flex: 1; height: 1px; background: #e5e7eb; margin: 0 8px; position: relative; overflow: hidden; }
    .line-fill { position: absolute; inset: 0; background: #0f172a; width: 0%; transition: width 0.4s ease; }

    /* Error */
    .err-box { font-size: 12px; color: #dc2626; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 13px; margin-bottom: 1rem; }

    /* Steps */
    .step { display: none; }
    .step.show { display: block; }

    /* Fields */
    .field { margin-bottom: 1.1rem; }
    label.lbl { display: block; font-size: 12px; font-weight: 500; color: #6b7280; margin-bottom: 6px; letter-spacing: 0.02em; }
    .req { color: #e53e3e; }
    input[type="text"],
    input[type="password"],
    input[type="number"],
    select {
      width: 100%; padding: 10px 13px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
      font-size: 14px; font-family: 'DM Sans', sans-serif;
      color: #0f172a; outline: none;
      transition: border-color 0.2s, background 0.2s;
    }
    input::placeholder { color: #d1d5db; }
    input:focus, select:focus { border-color: #0f172a; background: #fff; }
    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* Role cards */
    .roles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 6px; }
    .role-card {
      border: 1px solid #e5e7eb;
      border-radius: 8px; padding: 14px 10px; text-align: center;
      cursor: pointer; background: #f9fafb;
      transition: all 0.2s; user-select: none;
    }
    .role-card:hover { border-color: #9ca3af; background: #f3f4f6; }
    .role-card.sel { border: 2px solid #0f172a; background: #fff; }
    .role-card i { font-size: 22px; color: #9ca3af; display: block; margin-bottom: 6px; }
    .role-card.sel i { color: #0f172a; }
    .role-name { font-size: 12px; font-weight: 600; color: #6b7280; }
    .role-card.sel .role-name { color: #0f172a; }
    .role-desc { font-size: 10px; color: #9ca3af; margin-top: 3px; }

    /* Upload */
    .upload-zone {
      border: 1px dashed #d1d5db;
      border-radius: 8px; padding: 2rem; text-align: center;
      cursor: pointer; background: #f9fafb;
      transition: border-color 0.2s; position: relative;
    }
    .upload-zone:hover { border-color: #6b7280; }
    .upload-zone input[type="file"] {
      position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .upload-zone i { font-size: 28px; color: #9ca3af; margin-bottom: 8px; display: block; }
    .upload-zone p { font-size: 13px; color: #6b7280; }
    .upload-zone p strong { color: #0f172a; font-weight: 500; }
    .upload-zone small { font-size: 11px; color: #9ca3af; }

    .preview-wrap {
      display: none; align-items: center; gap: 12px;
      padding: 10px 13px; border: 1px solid #e5e7eb;
      border-radius: 8px; margin-bottom: 10px;
    }
    .preview-wrap img { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 1px solid #e5e7eb; }
    .preview-info { flex: 1; font-size: 13px; color: #6b7280; }
    .preview-rm { font-size: 12px; color: #dc2626; cursor: pointer; background: none; border: none; font-family: 'DM Sans', sans-serif; font-weight: 500; }

    /* Buttons */
    .btn-row { display: flex; gap: 10px; margin-top: 1.75rem; }
    .btn {
      flex: 1; padding: 11px 16px;
      border-radius: 8px;
      font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; border: 1px solid #e5e7eb;
      transition: all 0.2s; letter-spacing: 0.01em; display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .btn-primary { background: #0f172a; color: #fff; border-color: #0f172a; }
    .btn-primary:hover { background: #1e293b; border-color: #1e293b; }
    .btn-ghost { background: transparent; color: #6b7280; }
    .btn-ghost:hover { background: #f3f4f6; color: #0f172a; }

    /* Footer */
    .foot { text-align: center; margin-top: 1.5rem; font-size: 12px; color: #9ca3af; }
    .foot a { color: #0f172a; font-weight: 500; text-decoration: none; }
    .foot a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
      .card { padding: 1.75rem 1.25rem; }
      .row2 { grid-template-columns: 1fr; }
      .roles { grid-template-columns: 1fr 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="card">
  <form id="registerForm" action="/user/signup" method="POST" enctype="multipart/form-data" novalidate>

    <div class="brand">
      <div class="logo"><i class="ti ti-target"></i></div>
      <div>
        <div class="brand-name">Interview Portal</div>
        <div class="brand-sub">Career prep, simplified</div>
      </div>
    </div>

    <h1 id="ttl">Create your account</h1>
    <p class="sub" id="sub">Step 1 of 3 — Personal details</p>

    <div class="steps">
      <div class="step-item"><div class="dot active" id="d1">1</div></div>
      <div class="line"><div class="line-fill" id="l1"></div></div>
      <div class="step-item"><div class="dot" id="d2">2</div></div>
      <div class="line"><div class="line-fill" id="l2"></div></div>
      <div class="step-item"><div class="dot" id="d3">3</div></div>
    </div>

    <!-- EJS error block — keep as-is for your template engine -->
    <!-- <% if (locals.error) { %> -->
    <!-- <div class="err-box"><%= error %></div> -->
    <!-- <% } %> -->

    <!-- Step 1: Personal details -->
    <div class="step show" id="s1">
      <div class="field">
        <label class="lbl" for="fullname">Full name <span class="req">*</span></label>
        <input type="text" id="fullname" name="fullname" placeholder="e.g. Dhruvil Shah" required minlength="2" autocomplete="name" />
      </div>
      <div class="row2">
        <div class="field">
          <label class="lbl" for="age">Age <span class="req">*</span></label>
          <input type="number" id="age" name="age" placeholder="22" required min="16" max="100" />
        </div>
        <div class="field">
          <label class="lbl" for="gender">Gender <span class="req">*</span></label>
          <select id="gender" name="gender" required>
            <option value="">Select</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
            <option value="nonbinary">Non-binary</option>
            <option value="prefer-not">Prefer not to say</option>
          </select>
        </div>
      </div>
      <div class="btn-row">
        <button type="button" class="btn btn-primary" onclick="goTo(2)">Continue <i class="ti ti-arrow-right"></i></button>
      </div>
    </div>

    <!-- Step 2: Account & qualifications -->
    <div class="step" id="s2">
      <div class="field">
        <label class="lbl" for="username">Username <span class="req">*</span></label>
        <input type="text" id="username" name="username" placeholder="e.g. dhruvil_dev" required minlength="3" autocomplete="username" />
      </div>
      <div class="field">
        <label class="lbl" for="password">Password <span class="req">*</span></label>
        <input type="password" id="password" name="password" placeholder="Min. 8 characters" required minlength="8" autocomplete="new-password" />
      </div>
      <div class="field">
        <label class="lbl" for="qualifications">Qualification <span class="req">*</span></label>
        <select id="qualifications" name="qualifications" required>
          <option value="">Select highest qualification</option>
          <option value="high-school">High School</option>
          <option value="12th-grade">12th Grade</option>
          <option value="diploma">Diploma</option>
          <option value="btech">B.Tech / B.E.</option>
          <option value="bsc">B.Sc</option>
          <option value="bca">BCA</option>
          <option value="bcom">B.Com</option>
          <option value="mca">MCA</option>
          <option value="mtech">M.Tech / M.E.</option>
          <option value="msc">M.Sc</option>
          <option value="mba">MBA</option>
          <option value="phd">PhD</option>
          <option value="associate">Associate Degree</option>
          <option value="bootcamp">Bootcamp Certificate</option>
          <option value="self-taught">Self-Taught</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="btn-row">
        <button type="button" class="btn btn-ghost" onclick="goTo(1)"><i class="ti ti-arrow-left"></i> Back</button>
        <button type="button" class="btn btn-primary" onclick="goTo(3)">Continue <i class="ti ti-arrow-right"></i></button>
      </div>
    </div>

    <!-- Step 3: Photo & role -->
    <div class="step" id="s3">
      <div class="field">
        <label class="lbl">Profile photo <span style="font-weight:400;color:#9ca3af">(optional)</span></label>
        <div class="preview-wrap" id="preview-wrap">
          <img id="preview-img" src="" alt="Profile preview" />
          <div class="preview-info" id="preview-name">Photo selected</div>
          <button type="button" class="preview-rm" onclick="removePhoto()">Remove</button>
        </div>
        <div class="upload-zone" id="upload-zone">
          <input type="file" id="photo-input" name="photo" accept="image/*" onchange="previewPhoto(event)" />
          <i class="ti ti-camera-plus"></i>
          <p>Drag & drop or <strong>browse</strong> to upload</p>
          <small>JPG, PNG, WEBP · Max 5 MB</small>
        </div>
      </div>

      <div class="field" style="margin-top:1.25rem">
        <label class="lbl">Select your role <span class="req">*</span></label>
        <div class="roles">
          <div class="role-card" onclick="selectRole(this,'frontend')" tabindex="0">
            <i class="ti ti-layout-2"></i>
            <div class="role-name">Frontend</div>
            <div class="role-desc">UI · React · CSS</div>
            <input type="radio" name="role" value="frontend" style="display:none" />
          </div>
          <div class="role-card" onclick="selectRole(this,'backend')" tabindex="0">
            <i class="ti ti-server"></i>
            <div class="role-name">Backend</div>
            <div class="role-desc">APIs · DBs · Logic</div>
            <input type="radio" name="role" value="backend" style="display:none" />
          </div>
          <div class="role-card" onclick="selectRole(this,'cybersecurity')" tabindex="0">
            <i class="ti ti-shield-lock"></i>
            <div class="role-name">Security</div>
            <div class="role-desc">Networks · Hacking</div>
            <input type="radio" name="role" value="cybersecurity" style="display:none" />
          </div>
        </div>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-ghost" onclick="goTo(2)"><i class="ti ti-arrow-left"></i> Back</button>
        <button type="submit" class="btn btn-primary"><i class="ti ti-rocket"></i> Register</button>
      </div>
    </div>

  </form>
  <p class="foot">Already have an account? <a href="login">Sign in</a></p>
</div>

<script>
  const titles = ['Create your account', 'Account & qualifications', 'Photo & role'];
  const subs   = ['Step 1 of 3 — Personal details', 'Step 2 of 3 — Credentials & education', 'Step 3 of 3 — Almost done'];
  let cur = 1;

  function validateStep(n) {
    const fields = document.querySelectorAll(`#s${n} [required]`);
    for (let f of fields) {
      if (!f.reportValidity()) return false;
    }
    return true;
  }

  function goTo(n) {
    if (n > cur && !validateStep(cur)) return;
    document.getElementById('s' + cur).classList.remove('show');
    document.getElementById('s' + n).classList.add('show');
    document.getElementById('ttl').textContent = titles[n - 1];
    document.getElementById('sub').textContent = subs[n - 1];
    for (let i = 1; i <= 3; i++) {
      const d = document.getElementById('d' + i);
      if (i < n) { d.className = 'dot done'; d.innerHTML = '<i class="ti ti-check" style="font-size:13px"></i>'; }
      else if (i === n) { d.className = 'dot active'; d.textContent = i; }
      else { d.className = 'dot'; d.textContent = i; }
    }
    document.getElementById('l1').style.width = n > 1 ? '100%' : '0%';
    document.getElementById('l2').style.width = n > 2 ? '100%' : '0%';
    cur = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function selectRole(el, role) {
    document.querySelectorAll('.role-card').forEach(r => {
      r.classList.remove('sel');
      r.querySelector('input[type="radio"]').checked = false;
    });
    el.classList.add('sel');
    el.querySelector('input[type="radio"]').checked = true;
  }

  function previewPhoto(e) {
    const f = e.target.files[0];
    if (!f) return;
    const r = new FileReader();
    r.onload = ev => {
      document.getElementById('preview-img').src = ev.target.result;
      document.getElementById('preview-name').textContent = f.name;
      document.getElementById('preview-wrap').style.display = 'flex';
      document.getElementById('upload-zone').style.display = 'none';
    };
    r.readAsDataURL(f);
  }

  function removePhoto() {
    document.getElementById('photo-input').value = '';
    document.getElementById('preview-wrap').style.display = 'none';
    document.getElementById('upload-zone').style.display = 'block';
  }
</script>
</body>
</html>
