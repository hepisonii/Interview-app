<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In – Interview Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100vh;
      font-family: 'DM Sans', sans-serif;
      background: #f8f8f6;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .card {
      width: 100%;
      max-width: 480px;
      background: #ffffff;
      border: 1px solid #e4e4e0;
      border-radius: 20px;
      padding: 2.5rem 2.25rem;
      box-shadow: 0 2px 24px rgba(0,0,0,0.06);
    }

    /* Brand */
    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1.75rem; }
    .logo {
      width: 36px; height: 36px; border-radius: 10px;
      background: #0f172a; display: flex; align-items: center; justify-content: center;
    }
    .logo i { color: #fff; font-size: 18px; }
    .brand-name { font-size: 13px; font-weight: 600; color: #0f172a; letter-spacing: 0.04em; text-transform: uppercase; }
    .brand-sub { font-size: 11px; color: #9ca3af; margin-top: 1px; }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 30px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 500;
      color: #0f172a;
      margin-bottom: 1.25rem;
    }

    /* Heading */
    h1 { font-family: 'Playfair Display', serif; font-size: 26px; color: #0f172a; margin-bottom: 0.25rem; line-height: 1.25; }
    .sub { font-size: 13px; color: #6b7280; margin-bottom: 1.75rem; }

    /* Error */
    .err-box { font-size: 12px; color: #dc2626; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 13px; margin-bottom: 1.25rem; }

    /* Fields */
    .field { margin-bottom: 1.1rem; }
    label { display: block; font-size: 12px; font-weight: 500; color: #6b7280; margin-bottom: 6px; letter-spacing: 0.02em; }
    .req { color: #dc2626; }
    input[type="text"],
    input[type="password"] {
      width: 100%; padding: 10px 13px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
      font-size: 14px; font-family: 'DM Sans', sans-serif;
      color: #0f172a; outline: none;
      transition: border-color 0.2s, background 0.2s;
    }
    input::placeholder { color: #d1d5db; }
    input:focus { border-color: #0f172a; background: #fff; }

    /* Checkbox Group */
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 1.5rem;
      user-select: none;
    }
    .checkbox-group input[type="checkbox"] {
      width: 16px;
      height: 16px;
      cursor: pointer;
      accent-color: #0f172a;
    }
    .checkbox-group label {
      margin: 0;
      font-size: 13px;
      color: #4b5563;
      cursor: pointer;
      font-weight: 400;
    }

    /* Buttons */
    .btn-row { display: flex; gap: 10px; margin-top: 1.75rem; }
    .btn {
      flex: 1; padding: 11px 16px;
      border-radius: 8px;
      font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; border: 1px solid #e5e7eb;
      transition: all 0.2s; letter-spacing: 0.01em; display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .btn-primary { background: #0f172a; color: #fff; border-color: #0f172a; }
    .btn-primary:hover { background: #1e293b; border-color: #1e293b; }

    /* Footer */
    .foot { text-align: center; margin-top: 1.5rem; font-size: 12px; color: #9ca3af; }
    .foot a { color: #0f172a; font-weight: 500; text-decoration: none; }
    .foot a:hover { text-decoration: underline; }
  </style>
</head>
<body>
<div class="card">
  <form id="loginForm" action="/user/login" method="POST">
    
    <div class="brand">
      <div class="logo"><i class="ti ti-target"></i></div>
      <div>
        <div class="brand-name">Interview Portal</div>
        <div class="brand-sub">Career prep, simplified</div>
      </div>
    </div>

    <div class="badge"><i class="ti ti-shield-check"></i> Identity Verification</div>
    
    <h1>Welcome Back</h1>
    <p class="sub">Sign in to your account to continue</p>

    <!-- Error container -->
    <% if (locals.error) { %>
      <div class="err-box"><i class="ti ti-alert-circle"></i> <%= error %></div>
    <% } %>

    <div class="field">
      <label for="username">Username <span class="req">*</span></label>
      <input
        type="text"
        id="username"
        name="username"
        placeholder="e.g. dhruvil_dev"
        required />
    </div>
    
    <div class="field">
      <label for="password">Password <span class="req">*</span></label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="Enter your password"
        required
        minlength="6" />
    </div>
    
    <div class="checkbox-group">
      <input type="checkbox" id="remember" name="remember" />
      <label for="remember">Remember me on this engine</label>
    </div>

    <div class="btn-row">
      <button type="submit" class="btn btn-primary"><i class="ti ti-lock-open"></i> Access Account</button>
    </div>
  </form>
  
  <p class="foot">Don't have an account? <a href="/user/signup">Create one</a></p>
</div>
</body>
</html>