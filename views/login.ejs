<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In – Interview Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100vh;
      font-family: 'DM Sans', sans-serif;
      background: #f8f8f6;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    /* Card scales to wrap the wider inputs */
    .card {
      width: 100%;
      max-width: 600px;
      background: #ffffff;
      border: 1px solid #e4e4e0;
      border-radius: 20px;
      padding: 2.75rem 5.25rem;
      box-shadow: 0 2px 24px rgba(0,0,0,0.06);
    }

    /* Brand */
    .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1.75rem; }
    .logo {
      width: 36px; height: 36px; border-radius: 10px;
      background: #0f172a; display: flex; align-items: center; justify-content: center;
    }
    .logo i { color: #fff; font-size: 18px; }
    .brand-name { font-size: 13px; font-weight: 600; color: #0f172a; letter-spacing: 0.04em; text-transform: uppercase; }
    .brand-sub { font-size: 11px; color: #9ca3af; margin-top: 1px; }

    /* Heading */
h1 { 
  font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif; 
  font-size: 28px; 
  color: #0f172a; 
  margin-bottom: 0.25rem; 
  line-height: 1.25; 
}
    .sub { font-size: 13px; color: #6b7280; margin-bottom: 1.75rem; }

    /* Error */
    .err-box {
      font-size: 13px; color: #dc2626;
      background: #fef2f2; border: 1px solid #fecaca;
      border-radius: 8px; padding: 12px 15px;
      margin-bottom: 1.25rem;
      display: flex; align-items: center; gap: 6px;
      width: 120%;
      margin-left: -10%;
    }

    /* Fields — inputs at 120% width, centred via negative margins */
    .field { margin-bottom: 1.4rem; }
    label.lbl {
      display: block;
      font-size: 13px; font-weight: 500;
      color: #6b7280;
      margin-bottom: 8px;
      letter-spacing: 0.02em;
      width: 120%;
      margin-left: -10%;
    }
    .req { color: #e53e3e; }

    input[type="text"],
    input[type="password"] {
      width: 120%;
      margin-left: -10%;
      padding: 15px 18px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
      font-size: 15px;
      font-family: 'DM Sans', sans-serif;
      color: #0f172a;
      outline: none;
      transition: border-color 0.2s, background 0.2s;
      display: block;
    }
    input::placeholder { color: #d1d5db; }
    input:focus { border-color: #0f172a; background: #fff; }

    /* Remember me — aligned to input left edge */
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 0.25rem;
      margin-left: -10%;
      user-select: none;
    }
    .checkbox-group input[type="checkbox"] {
      width: 15px; height: 15px;
      cursor: pointer;
      accent-color: #0f172a;
      flex-shrink: 0;
    }
    .checkbox-group label {
      font-size: 13px;
      color: #6b7280;
      cursor: pointer;
      font-weight: 400;
      letter-spacing: 0.02em;
    }

    /* Button — same 120% width as inputs */
    .btn-row { display: flex; gap: 10px; margin-top: 1.75rem; width: 120%; margin-left: -10%; }
    .btn {
      flex: 1;
      padding: 15px 16px;
      border-radius: 8px;
      font-size: 15px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; border: 1px solid #e5e7eb;
      transition: all 0.2s; letter-spacing: 0.01em;
      display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .btn-primary { background: #0f172a; color: #fff; border-color: #0f172a; }
    .btn-primary:hover { background: #1e293b; border-color: #1e293b; }

    /* Footer */
    .foot { text-align: center; margin-top: 1.5rem; font-size: 12px; color: #9ca3af; }
    .foot a { color: #0f172a; font-weight: 500; text-decoration: none; }
    .foot a:hover { text-decoration: underline; }

    @media (max-width: 560px) {
      .card { padding: 1.75rem 1.5rem; }
      input[type="text"], input[type="password"] { width: 100%; margin-left: 0; }
      label.lbl { width: 100%; margin-left: 0; }
      .btn-row { width: 100%; margin-left: 0; }
      .checkbox-group { margin-left: 0; }
      .err-box { width: 100%; margin-left: 0; }
    }
  </style>
</head>
<body>
<div class="card">
  <form id="loginForm" action="/user/login" method="POST" novalidate>

    <div class="brand">
      <div class="logo"><i class="ti ti-target"></i></div>
      <div>
        <div class="brand-name">Interview Portal</div>
        <div class="brand-sub">Career prep, simplified</div>
      </div>
    </div>

    <h1>Welcome back</h1>
    <p class="sub">Sign in to continue your prep</p>

    <% if (locals.error) { %>
      <div class="err-box"><i class="ti ti-alert-circle"></i> <%= error %></div>
    <% } %>

    <div class="field">
      <label class="lbl" for="username">Username <span class="req">*</span></label>
      <input
        type="text"
        id="username"
        name="username"
        placeholder="e.g. dhruvil_dev"
        required
        autocomplete="username" />
    </div>

    <div class="field">
      <label class="lbl" for="password">Password <span class="req">*</span></label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="Enter your password"
        required
        minlength="6"
        autocomplete="current-password" />
    </div>

    <div class="checkbox-group">
      <input type="checkbox" id="remember" name="remember" />
      <label for="remember">Remember me on this device</label>
    </div>

    <div class="btn-row">
      <button type="submit" class="btn btn-primary">
        <i class="ti ti-lock-open"></i> Sign in
      </button>
    </div>

  </form>

  <p class="foot">Don't have an account? <a href="/user/signup">Create one</a></p>
</div>
</body>
</html>
